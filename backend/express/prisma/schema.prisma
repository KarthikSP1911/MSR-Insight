// This is your Prisma schema file
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  usn          String               @id
  name         String
  dob          String?
  phone        String?
  email        String?
  current_year Int
  details      Json                 // For backward compatibility / performance metrics
  parents      Parent[]
  proctor_maps ProctorStudentMap[]

  @@map("students")
}

model Proctor {
  proctor_id    String               @id
  name          String
  phone         String?
  email         String?
  password_hash String
  student_maps  ProctorStudentMap[]

  @@map("proctors")
}

model Parent {
  usn      String
  relation String
  name     String
  phone    String
  email    String
  student  Student @relation(fields: [usn], references: [usn])

  @@id([usn, relation])
  @@map("parents")
}

model ProctorStudentMap {
  id            Int     @id @default(autoincrement())
  proctor_id    String
  student_id    String
  academic_year String
  proctor       Proctor @relation(fields: [proctor_id], references: [proctor_id])
  student       Student @relation(fields: [student_id], references: [usn])

  @@unique([student_id, academic_year])
  @@map("proctor_student_map")
}

model ScrapeMetric {
  id                  Int       @id @default(autoincrement())
  usn                 String
  strategy            String    // "traditional" | "piggyback"
  initiated_at        DateTime  @default(now())
  completed_at        DateTime?
  latency_ms          Int?
  freshness_offset_ms Int?
  detected            Boolean   @default(false)
  navigator_webdriver Boolean?
  error_message       String?
  payload_size_bytes  Int?

  @@map("scrape_metrics")
}
