# FastAPI Backend Environment Variables

# Groq API Key for AI Remark Generation
GROQ_API_KEY=your_groq_api_key_here

# Groq Model to use
GROQ_MODEL=llama-3.1-8b-instant

# FastAPI Port
PORT=8000

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Express API URL for data synchronization
EXPRESS_API_URL=http://localhost:5001/api/students/sync
